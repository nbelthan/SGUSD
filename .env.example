# =============================================================================
# SageBridge — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Privy — Embedded wallet & email-based authentication
# Get your App ID at https://dashboard.privy.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# -----------------------------------------------------------------------------
# Sagecoin (SGUSD) — Deployed contract address on Base Sepolia
# This will be set after running: bash contracts/deploy.sh
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SAGECOIN_ADDRESS=your_deployed_contract_address_here

# -----------------------------------------------------------------------------
# Base Sepolia RPC — Public endpoint (no API key needed)
# You can also use Alchemy/Infura for higher rate limits
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# -----------------------------------------------------------------------------
# Deployer Private Key — Used ONLY for contract deployment (deploy.sh)
# DO NOT commit a real private key. Fund this wallet with Base Sepolia ETH.
# Faucet: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
# -----------------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
